# Shopkeeper AI — API Keys
# All EXPO_PUBLIC_ variables are bundled at build time.
# After editing this file, restart the Expo dev server (press s → r, or Ctrl+C and re-run).

# ── Voice Transcription — PRIMARY (fast & cheap, ~$0.02/hr) ─────────────────
# Get at: https://console.groq.com → API Keys
EXPO_PUBLIC_GROQ_KEY=

# ── Smart Inventory Extraction — Gemini 2.0 Flash ───────────────────────────
# Get at: https://aistudio.google.com/apikey
EXPO_PUBLIC_GEMINI_KEY=

# ── Voice Transcription — FALLBACK (only used if Groq key is absent/fails) ──
# Get at: https://platform.openai.com/api-keys
EXPO_PUBLIC_OPENAI_KEY=

# ── Photo Product Recognition — Google Cloud Vision ─────────────────────────
# Enable "Cloud Vision API" at: https://console.cloud.google.com
EXPO_PUBLIC_GOOGLE_VISION_KEY=

# ── Cloud Sync — Supabase ────────────────────────────────────────────────────
# Create a free project at: https://supabase.com
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=


EAS_SKIP_AUTO_FINGERPRINT=1