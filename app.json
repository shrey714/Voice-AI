{
  "expo": {
    "name": "Shopkeeper AI",
    "slug": "shopkeeper-app",
    "version": "1.0.0",
    "sdkVersion": "56.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.shopkeeperai.app",
      "supportsTablet": false,
      "infoPlist": {
        "NSCameraUsageDescription": "Camera is used to scan barcodes of products",
        "NSMicrophoneUsageDescription": "Microphone is used for voice-based billing",
        "NSSpeechRecognitionUsageDescription": "Speech recognition is used to convert voice to product orders",
        "NSLocationWhenInUseUsageDescription": "Location is used to set your shop's pickup location for online orders"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#5B7567",
        "foregroundImage": "./assets/adaptive-icon.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "googleServicesFile": "./google-services.json",
      "softwareKeyboardLayoutMode": "pan",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.VIBRATE",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "package": "com.shopkeeperai.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-sqlite",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Shopkeeper AI to use the camera for barcode scanning"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Shopkeeper AI to access photos for product images"
        }
      ],
      "expo-audio",
      "expo-asset",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Shopkeeper AI to use your location to set your shop's pickup location for online orders"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/adaptive-icon.png",
          "color": "#5B7567",
          "defaultChannel": "online-orders",
          "sounds": []
        }
      ],
      "expo-sharing",
      "expo-status-bar",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#5B7567"
        }
      ],
      "expo-image"
    ],
    "extra": {
      "eas": {
        "projectId": "e725c1ba-c15e-437c-b5f7-189f3122cff1"
      }
    }
  }
}
